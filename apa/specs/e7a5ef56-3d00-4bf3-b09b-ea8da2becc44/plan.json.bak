    {
      "id": "api",
      "name": "Crear api.py",
      "description": "Implementa una API FastAPI con los siguientes endpoints:\n- `POST /tasks` → recibe JSON `{\"title\": str}` y retorna la tarea creada (JSON de Task) con código 201.\n- `GET /tasks` → retorna lista de todas las tareas (opcional query param `completed_only`).\n- `GET /tasks/{task_id}` → retorna una tarea por id o 404 si no existe.\n- `PUT /tasks/{task_id}/complete` → marca la tarea como completada, retorna la tarea actualizada o 404.\n\nUtiliza las clases de `models/task.py` y las validaciones de `utils/validators.py`.\nLa aplicación debe ejecutarse con `uvicorn` si se llama directamente.",
      "depends_on": [
        "models_task",
        "utils_validators"
      ],
      "inputs": [
        "models/task.py",
        "utils/validators.py",
        "completed_only",
        "uvicorn"
